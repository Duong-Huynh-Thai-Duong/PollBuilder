@model PollBuilder.Application.DTOs.Polls.PollResponseDTO
@{
    ViewData["Title"] = "Poll Created Successfully!";
}

<div class="container mt-5 text-center" style="max-width: 600px;">
    <div class="card shadow-lg border-0" style="border-radius: 15px;">
        <div class="card-body p-5">

            <!-- Success Checkmark -->
            <div class="mb-4">
                <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
            </div>

            <h1 class="display-5 fw-bold text-dark mb-3">Poll Published!</h1>
            <p class="lead text-muted mb-4">Your poll "<strong>@Model.Title</strong>" is now live and ready for votes.</p>

            <!-- Shareable Link Box -->
            <div class="bg-light p-4 rounded mb-4 border">
                <h5 class="fw-bold mb-3">Share this link with your voters:</h5>
                <div class="input-group input-group-lg">
                    <input type="text" id="pollLinkInput" class="form-control bg-white text-primary fw-bold" value="@ViewBag.PollLink" readonly />
                    <button class="btn btn-primary" type="button" onclick="copyPollLink()">
                        <i class="fas fa-copy"></i> Copy
                    </button>
                </div>
               
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a href="/dashboard" class="btn btn-outline-secondary btn-lg fw-bold px-4">
                    <i class="fas fa-home me-2"></i> Dashboard
                </a>
                <a href="@ViewBag.PollLink" target="_blank" class="btn btn-success btn-lg fw-bold px-4">
                    <i class="fas fa-external-link-alt me-2"></i> View Poll
                </a>
            </div>

        </div>
    </div>
</div>

<script>
    function copyPollLink() {
        var copyText = document.getElementById("pollLinkInput");
        copyText.select();
        copyText.setSelectionRange(0, 99999); /* For mobile devices */
        navigator.clipboard.writeText(copyText.value).then(() => {
            alert("Link copied to clipboard!");
        });
    }
</script>
