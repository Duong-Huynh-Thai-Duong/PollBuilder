@model PollBuilder.MVC.ViewModels.PollBuilderViewModel

@{
    ViewData["Title"] = "Create a New Poll";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">⚡ Fast Poll Builder</h2>
            <p class="text-muted">Quick multiple-choice questions. Max 6 options per question.</p>
        </div>
    </div>

    <form asp-controller="Creator" asp-action="CreatePoll" method="post" id="poll-builder-form">

        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-body">
                <label asp-for="FormTitle" class="form-label fw-bold text-primary">Poll Title</label>
                <input asp-for="FormTitle" class="form-control form-control-lg" placeholder="e.g., Friday Team Lunch Destination" />
                <span asp-validation-for="FormTitle" class="text-danger fw-bold"></span>
            </div>
        </div>

        <div id="questions-canvas" class="row mb-4">
        </div>

        <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded shadow-sm">
            <button type="button" id="add-question-btn" class="btn btn-outline-primary fw-bold">
                ➕ Add Question
            </button>
            <button type="submit" class="btn btn-success btn-lg px-5 fw-bold">
                🚀 Publish Poll
            </button>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3 fw-bold"></div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const canvas = document.getElementById('questions-canvas');
            const addQuestionBtn = document.getElementById('add-question-btn');

            // 1. Generate a Simplified Question Card
            addQuestionBtn.addEventListener('click', () => {
                const questionHtml = `
                    <div class="col-12 question-card mb-4">
                        <div class="card shadow-sm border-secondary">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-3">
                                    <h5 class="card-title text-secondary fw-bold">Multiple Choice Question</h5>
                                    <button type="button" class="btn btn-sm btn-outline-danger remove-question-btn">🗑️ Remove</button>
                                </div>

                                <input type="text" class="form-control form-control-lg mb-3 question-text" placeholder="Type your question here..." required />

                                <input type="hidden" class="question-type" value="MultipleChoice" />

                                <div class="options-wrapper">
                                    <h6 class="text-muted fw-bold">Options (Max 6)</h6>
                                    <div class="options-container"></div>
                                    <button type="button" class="btn btn-sm btn-outline-primary mt-2 add-option-btn">➕ Add Option</button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                canvas.insertAdjacentHTML('beforeend', questionHtml);

                const newCard = canvas.lastElementChild;
                const optionsContainer = newCard.querySelector('.options-container');
                addOption(optionsContainer);
                addOption(optionsContainer);

                reindex();
            });

            // 2. Handle Button Clicks
            canvas.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-question-btn')) {
                    e.target.closest('.question-card').remove();
                    reindex();
                }

                if (e.target.classList.contains('add-option-btn')) {
                    const container = e.target.closest('.card-body').querySelector('.options-container');
                    addOption(container);
                    reindex();
                }

                if (e.target.classList.contains('remove-option-btn')) {
                    const container = e.target.closest('.options-container');
                    e.target.closest('.option-row').remove();

                    const btn = container.parentElement.querySelector('.add-option-btn');
                    btn.style.display = 'inline-block';
                    reindex();
                }
            });

            // 3. Helper: Adds options and enforces the Max 6 rule
            function addOption(container) {
                if (container.querySelectorAll('.option-row').length >= 6) return;

                const optionHtml = `
                    <div class="input-group mb-2 option-row">
                        <input type="text" class="form-control option-text" placeholder="Option text..." required />
                        <button class="btn btn-outline-danger remove-option-btn" type="button">X</button>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', optionHtml);

                if (container.querySelectorAll('.option-row').length >= 6) {
                    container.parentElement.querySelector('.add-option-btn').style.display = 'none';
                }
            }

            // 4. Re-indexer
            function reindex() {
                const questions = document.querySelectorAll('.question-card');

                questions.forEach((q, qIndex) => {
                    q.querySelector('.question-text').name = \`Questions[\${qIndex}].QuestionText\`;
                    q.querySelector('.question-type').name = \`Questions[\${qIndex}].QuestionType\`;

                    const options = q.querySelectorAll('.option-text');
                    options.forEach((opt, oIndex) => {
                        opt.name = \`Questions[\${qIndex}].Options[\${oIndex}].OptionText\`;
                    });
                });
            }

            addQuestionBtn.click();
        });
    </script>
}
