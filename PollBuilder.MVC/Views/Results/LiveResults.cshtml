@model PollBuilder.MVC.ViewModels.PollResultsViewModel

@{
    ViewData["Title"] = "Live Results - " + Model.PollTitle;
}

<div class="container mt-5" style="max-width: 800px;">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">📊 @Model.PollTitle</h1>
        <p class="text-muted fs-4">
            Total Responses: <span class="badge bg-success fs-5">@Model.TotalPollVotes</span>
        </p>
    </div>

    @foreach (var question in Model.Questions)
    {
        <div class="card shadow-sm mb-5 border-0 bg-light">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-2">@question.QuestionText</h4>
                <p class="text-muted small mb-4">@question.TotalQuestionVotes votes on this question</p>

                @* @foreach (var option in question.Options)
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-end mb-1">
                            <span class="fw-bold fs-5">@option.OptionText</span>
                            <span class="text-muted fw-bold">
                                @option.VotePercentage.ToString("0.0")% (@option.VoteCount votes)
                            </span>
                        </div>

                        <div class="progress shadow-sm" style="height: 30px; border-radius: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                                 role="progressbar"
                                 style="width: @option.VotePercentage%;"
                                 aria-valuenow="@option.VotePercentage"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>
                    </div>
                } *@

                @if (question.Type == PollBuilder.Domain.Enums.QuestionType.OpenText)
                {
                    <div class="mt-3">
                        @if (question.TextResponses != null && question.TextResponses.Any())
                        {
                            <ul class="list-group">
                                @foreach (var answer in question.TextResponses)
                                {
                                    <li class="list-group-item bg-light border-0 mb-2 rounded">
                                        <i class="fas fa-comment text-primary me-2"></i> @answer
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted fst-italic">No responses yet.</p>
                        }
                    </div>
                }
                else
                {
                    <!-- Standard Progress Bar Loop for non-text questions -->
                    @foreach (var option in question.Options)
                    {
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-end mb-1">
                                <span class="fw-bold fs-5">@option.OptionText</span>
                                <span class="text-muted fw-bold">
                                    @option.VotePercentage.ToString("0.0")% (@option.VoteCount votes)
                                </span>
                            </div>

                            <div class="progress shadow-sm" style="height: 30px; border-radius: 10px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                                     role="progressbar"
                                     style="width: @option.VotePercentage%;"
                                     aria-valuenow="@option.VotePercentage"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <div class="text-center mt-4 mb-5">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold">
            ⬅️ Back to Dashboard
        </a>
    </div>
</div>