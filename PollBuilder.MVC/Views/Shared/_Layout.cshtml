<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POSU</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&display=swap" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Geist+Pixel&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

 
</head>
<body>
    <header class="main-header">
        <div class="nav-container">
            <!-- The Logo -->
            <a class="nav-brand" asp-area="" asp-controller="Home" asp-action="Index">
                Posu
            </a>

            <!-- The Smart Navigation -->
            <div class="nav-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="nav-link-ghost" asp-controller="Dashboard" asp-action="Index">My Dashboard</a>

                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" style="display:inline;">
                        <button type="submit" class="nav-btn-small" style="cursor: pointer;">Logout</button>
                    </form>
                }
                else
                {
                    <a class="nav-link-ghost" asp-area="Identity" asp-page="/Account/Login">Log In</a>
                    <!-- Notice we are using your exact class: nav-btn-small -->
                    <a class="nav-btn-small" asp-area="Identity" asp-page="/Account/Register">Sign Up</a>
                }
            </div>
        </div>
    </header>

    <main role="main" class="main-container">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; 2026 - Built by Mun & Yun</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>