@{
    ViewData["Title"] = "Welcome";
}

<div class="landing-container text-center">
    <!-- Hero Section -->
    <div class="hero-section">
        <h1 class="hero-title">Welcome to ThruSub!</h1>
        <p class="hero-subtitle">
            Where you can freely create poll anywhere, anytime.
        </p>

        <div class="hero-actions d-flex justify-content-center mt-5">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Removed btn-red -->
                <a asp-controller="Dashboard" asp-action="Index" class="hero-btn shadow-sm">
                    Go to My Workspace
                </a>
            }
            else
            {
                <!-- Removed btn-red -->
                <a asp-area="Identity" asp-page="/Account/Register" class="hero-btn shadow-sm">
                    Create Your Poll Now !
                </a>
            }
        </div>
    </div>

   
</div>