@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <!-- Logo inside the auth card -->
        <div class="mb-4">
            <img src="~/images/logo.png" alt="ThruSub Logo" style="height: 48px;" />
        </div>

        <h2 class="fw-bold mb-1 text-dark" style="font-family: 'Google Sans', serif;">Welcome to ThruSub</h2>
        <p class="text-muted mb-4">Find new ideas to try</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold" role="alert"></div>

            <div class="form-floating mb-3 text-start">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="text-muted">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3 text-start">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="text-muted">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4 text-start">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button id="registerSubmit" type="submit" class="w-100 btn-red py-3 fs-5" style="border-radius: 30px;">Continue</button>
        </form>

        <div class="mt-4 pt-3 border-top">
            <p class="mb-0 text-muted fw-bold">
                Already a member? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-red">Log in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}